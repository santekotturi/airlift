<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Airlift</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- App Store: Health & Fitness category, and a standard-encryption-only
	     declaration so uploads skip the export-compliance prompt (the app uses
	     only HTTPS/Apple crypto). -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.healthcare-fitness</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- Expose Documents in the Files app / Finder so the opt-in debug dumps
	     (DEBUG builds with the -AirliftDumps launch argument) can be pulled
	     off-device. Documents is empty otherwise. -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- HealthKit usage strings (required for HKHealthStore authorization prompts) -->
	<key>NSHealthShareUsageDescription</key>
	<string>Airlift reads the sleep and health samples already in Apple Health so it can compare them with your Fitbit data and avoid writing duplicates.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Airlift writes your Fitbit data into Apple Health: sleep stages, heart rate, resting heart rate, HRV, SpO2, respiratory rate, steps, and distance.</string>

	<!-- Background execution: daily sync via BGAppRefreshTask -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER).sync</string>
	</array>

	<!-- OAuth client values, injected from Config.xcconfig at build time. -->
	<key>GHClientID</key>
	<string>$(GH_CLIENT_ID)</string>
	<key>GHReversedClientID</key>
	<string>$(GH_REVERSED_CLIENT_ID)</string>

	<!-- OAuth redirect: Google iOS clients use the reversed client ID as the
	     custom URL scheme. Populated from $(GH_REVERSED_CLIENT_ID). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER).oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(GH_REVERSED_CLIENT_ID)</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
